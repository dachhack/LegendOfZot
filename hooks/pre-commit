#!/usr/bin/env python3
"""Pre-commit hook: increment BUILD_NUMBER and update CHANGELOG in version.py."""

import subprocess
import re
import os

VERSION_FILE = os.path.join(os.path.dirname(__file__), '..', '..', 'wizardscavern', 'version.py')
VERSION_FILE = os.path.normpath(VERSION_FILE)

def main():
    # Read current version.py
    with open(VERSION_FILE, 'r') as f:
        content = f.read()

    # Increment BUILD_NUMBER
    match = re.search(r'BUILD_NUMBER\s*=\s*(\d+)', content)
    if not match:
        return
    old_build = int(match.group(1))
    new_build = old_build + 1
    content = re.sub(r'BUILD_NUMBER\s*=\s*\d+', f'BUILD_NUMBER = {new_build}', content)

    # Get recent git log entries (last 8 commits)
    try:
        result = subprocess.run(
            ['git', 'log', '--oneline', '-8', '--format=%s'],
            capture_output=True, text=True, timeout=5
        )
        entries = [line.strip() for line in result.stdout.strip().split('\n') if line.strip()]
    except Exception:
        entries = []

    # Update CHANGELOG list
    if entries:
        changelog_lines = ',\n'.join(f'    "{e}"' for e in entries)
        content = re.sub(
            r'CHANGELOG\s*=\s*\[.*?\]',
            f'CHANGELOG = [\n{changelog_lines},\n]',
            content,
            flags=re.DOTALL
        )

    # Write updated version.py
    with open(VERSION_FILE, 'w') as f:
        f.write(content)

    # Stage the updated file
    subprocess.run(['git', 'add', VERSION_FILE])

if __name__ == '__main__':
    main()
